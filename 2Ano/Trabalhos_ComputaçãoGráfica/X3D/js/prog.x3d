                    </shape>
                </transform>

            </transform>

            <!-- Animação -->
            <timeSensor DEF="Timer" cycleInterval="5" loop="true"></timeSensor>
            <positionInterpolator DEF="MoveBuilding" key="0 0.5 1" keyValue="0 -10 0 0 0 0 0 0 0">
            </positionInterpolator>
            <positionInterpolator DEF="Move1fila" key="0 0.5 1" keyValue="-20 0 0 0 0 0 0 0 0">
            </positionInterpolator>
            <positionInterpolator DEF="Move2fila" key=" 0 0.5 1" keyValue="20 0 0 0 0 0 0 0 0">
            </positionInterpolator>
            <positionInterpolator DEF="Move3fila" key="0 0.5 1" keyValue="0 20 0 0 0 0 0 0 0">
            </positionInterpolator>
            <positionInterpolator DEF="MoveDoor" key="0 0.5 1" keyValue="0 20 0 0 0 0 0 0 0">
            </positionInterpolator>
            <positionInterpolator DEF="MoveStreet" key="0 0.5 1" keyValue="0 5 0 0 0 0 0 0 0">
            </positionInterpolator>


            <route fromNode="Timer" fromField="fraction_changed" toNode="MoveBuilding" toField="set_fraction">
            </route>
            <route fromNode="Timer" fromField="fraction_changed" toNode="Move1fila" toField="set_fraction">
            </route>
            <route fromNode="Timer" fromField="fraction_changed" toNode="Move2fila" toField="set_fraction">
            </route>
            <route fromNode="Timer" fromField="fraction_changed" toNode="Move3fila" toField="set_fraction">
            </route>
            <route fromNode="Timer" fromField="fraction_changed" toNode="MoveDoor" toField="set_fraction">
            </route>
            <route fromNode="Timer" fromField="fraction_changed" toNode="MoveStreet" toField="set_fraction">
            </route>

            <route fromNode="MoveBuilding" fromField="value_changed" toNode="Building" toField="set_translation">
            </route>
            <route fromNode="Move1fila" fromField="value_changed" toNode="janela_1fila" toField="set_translation">
            </route>
            <route fromNode="Move2fila" fromField="value_changed" toNode="janela_2fila" toField="set_translation">
            </route>
            <route fromNode="Move3fila" fromField="value_changed" toNode="janela_3fila" toField="set_translation">
            </route>
            <route fromNode="MoveDoor" fromField="value_changed" toNode="door" toField="set_translation">
            </route>
            <route fromNode="MoveStreet" fromField="value_changed" toNode="street" toField="set_translation">
            </route>


