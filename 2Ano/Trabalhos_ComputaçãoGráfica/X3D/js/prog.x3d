<x3d>
        <scene>
            <!-- Iluminação e Ambiente -->
            <background skyColor="0.5 0.7 1"></background>
            <directionalLight direction="-1 -1 -1" intensity="0.8"></directionalLight>

            <!--Rua-->
            <transform DEF="street">
                <transform translation="0 -3 1.8">
                    <shape>
                        <box size="13 .1 1.5"></box>
                        <appearance>
                            <material diffuseColor=".1 .1 .1" specularColor="0.2 0.2 0.2"></material>
                        </appearance>
                    </shape>
                </transform>
                <transform translation="0 -2.98 1.8">
                    <shape>
                        <box size="13 .1 .1"></box>
                        <appearance>
                            <material diffuseColor="yellow" specularColor="0.2 0.2 0.2"></material>
                        </appearance>
                    </shape>
                </transform>
            </transform>

            <!-- Transformação Principal do Edifício -->
            <transform DEF="Building">
